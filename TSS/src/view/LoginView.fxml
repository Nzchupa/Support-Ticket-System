<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<!--
    LoginView.fxml
    ══════════════
    Änderungen gegenüber Original:
      • TextField für Passwörter → PasswordField (sichererer Input)
      • fx:id hinzugefügt für Controller-Binding
      • onAction="#handleLogin" / "#handleRegister" für Buttons
      • Fehler-/Statuslabels hinzugefügt (loginErrorLabel, registerMessageLabel)
-->

<AnchorPane
    xmlns="http://javafx.com/javafx"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="controller.LoginViewController">

    <children>
        <AnchorPane layoutX="0" layoutY="0"
                    prefHeight="400.0" prefWidth="500.0"
                    style="-fx-background-color: #2F4F4F;">
            <children>

                <!-- ── Login-Bereich ─────────────────────────────── -->
                <VBox layoutX="75.0" layoutY="20.0"
                      prefWidth="351.0" spacing="6.0">
                    <children>

                        <Label text="Login" textFill="#f8f5f5">
                            <font><Font name="System Bold" size="28.0"/></font>
                        </Label>

                        <TextField
                            fx:id="loginEmailField"
                            prefWidth="351.0"
                            promptText="E-Mail"/>

                        <!-- PasswordField statt TextField für sichere Eingabe -->
                        <PasswordField
                            fx:id="loginPasswordField"
                            prefWidth="351.0"
                            promptText="Passwort"/>

                        <Button
                            mnemonicParsing="false"
                            prefWidth="351.0"
                            style="-fx-background-color: #528B8B;"
                            text="Sign In"
                            textFill="WHITE"
                            onAction="#handleLogin">
                            <font><Font size="14.0"/></font>
                        </Button>

                        <!-- Fehlermeldung Login -->
                        <Label
                            fx:id="loginErrorLabel"
                            prefWidth="351.0"
                            text=""
                            wrapText="true"
                            style="-fx-text-fill: #FF6B6B; -fx-font-size: 12px;"/>
		

                <!-- ── Registrierungs-Bereich ────────────────────── -->
                <VBox layoutX="75.0" layoutY="210.0"
                      prefWidth="351.0" spacing="6.0">
                    <children>

                        <Label text="Kein Account?" textFill="#f8f5f5">
                            <font><Font name="System Bold" size="20.0"/></font>
                        </Label>

                        <TextField
                            fx:id="registerEmailField"
                            prefWidth="351.0"
                            promptText="E-Mail"/>

                        <PasswordField
                            fx:id="registerPasswordField"
                            prefWidth="351.0"
                            promptText="Passwort (min. 6 Zeichen)"/>

                        <Button
                            mnemonicParsing="false"
                            prefWidth="351.0"
                            style="-fx-background-color: #528B8B;"
                            text="Account erstellen"
                            textFill="WHITE"
                            onAction="#handleRegister">
                            <font><Font size="14.0"/></font>
                        </Button>

                        <!-- Status-Meldung Registrierung -->
                        <Label
                            fx:id="registerMessageLabel"
                            prefWidth="351.0"
                            text=""
                            wrapText="true"
                            style="-fx-font-size: 12px;"/>
<Button text="Zurück zur Home Page"
       		 onAction="#openHome"
       		 style="-fx-background-color: #1e293b; -fx-text-fill: white; -fx-background-radius: 8; -fx-padding: 10 20;" />
                    </children>
                </VBox>
                    </children>
                </VBox>

            </children>
        </AnchorPane>
    </children>
</AnchorPane>
