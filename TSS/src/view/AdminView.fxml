<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<ScrollPane fitToWidth="true"
            fx:controller="controller.NavigationController"
            style="-fx-background: #1e1e1e; -fx-background-color: #1e1e1e;"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml">

   <VBox fx:id="rootPane"
      spacing="15"
      style="-fx-background-color: #1e1e1e;">
        <padding>
            <Insets top="25" right="25" bottom="25" left="25"/>
        </padding>

        <VBox spacing="5">
            <Label text="🛠️ Admin Dashboard"
                   style="-fx-text-fill: white; -fx-font-size: 24; -fx-font-weight: bold;"/>
            <Label text="Systemkonfiguration &amp; Verwaltung"
                   style="-fx-text-fill: #888888; -fx-font-size: 12;"/>
        </VBox>

        <Separator style="-fx-opacity: 0.3;"/>

        <Label text="👤 Benutzerverwaltung"
               style="-fx-text-fill: #cccccc; -fx-font-weight: bold; -fx-font-size: 14;"/>

        <TextField promptText="🔍 Benutzer suchen..."
                   style="-fx-background-color: #2b2b2b; -fx-text-fill: white; -fx-prompt-text-fill: #888888; -fx-background-radius: 8; -fx-border-radius: 8; -fx-padding: 10;"/>

        <ListView prefHeight="150"
                  style="-fx-background-color: #2b2b2b; -fx-border-color: #444444; -fx-background-radius: 8; -fx-border-radius: 8;"/>

        <HBox spacing="10">
            <Button text="➕ Benutzer erstellen"
                    style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-background-radius: 8; -fx-padding: 8 16; -fx-cursor: hand; -fx-font-weight: bold;"/>
            <Button text="✏️ Bearbeiten"
                    style="-fx-background-color: #2196F3; -fx-text-fill: white; -fx-background-radius: 8; -fx-padding: 8 16; -fx-cursor: hand;"/>
            <Button text="🗑️ Löschen"
                    style="-fx-background-color: #f44336; -fx-text-fill: white; -fx-background-radius: 8; -fx-padding: 8 16; -fx-cursor: hand;"/>
        </HBox>

        <Separator style="-fx-opacity: 0.3;"/>
<Button text="⬅ Zurück zur Home Page"
        onAction="#openHome"
        style="-fx-background-color: #2563eb;
               -fx-text-fill: white;
               -fx-font-weight: bold;
               -fx-background-radius: 8;
               -fx-padding: 10 18;
               -fx-cursor: hand;"/>
        <Label text="⚙️ Ticket-Konfiguration (Kategorien, Status, Priorität)"
               style="-fx-text-fill: #cccccc; -fx-font-weight: bold; -fx-font-size: 14;"/>

        <HBox spacing="10" alignment="CENTER_LEFT">
            <ComboBox promptText="Typ wählen"
                      style="-fx-background-color: #2b2b2b; -fx-text-fill: white; -fx-background-radius: 8; -fx-cursor: hand;"/>
            <TextField promptText="Neuer Eintrag..." HBox.hgrow="ALWAYS"
                       style="-fx-background-color: #2b2b2b; -fx-text-fill: white; -fx-prompt-text-fill: #888888; -fx-background-radius: 8; -fx-padding: 8;"/>
            <Button text="➕ Hinzufügen"
                    style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-background-radius: 8; -fx-padding: 8 14; -fx-cursor: hand;"/>
        </HBox>
        
        <ListView prefHeight="100"
                  style="-fx-background-color: #2b2b2b; -fx-border-color: #444444; -fx-background-radius: 8;"/>

        <Separator style="-fx-opacity: 0.3;"/>

        <Label text="📜 System Logs"
               style="-fx-text-fill: #cccccc; -fx-font-weight: bold; -fx-font-size: 14;"/>

        <ListView prefHeight="120"
                  style="-fx-background-color: #1a1a1a; -fx-border-color: #444444; -fx-background-radius: 8; -fx-font-family: 'Consolas'; -fx-font-size: 11;"/>

        <HBox spacing="10">
            <Button text="🧹 Logs leeren"
                    style="-fx-background-color: #FF5722; -fx-text-fill: white; -fx-background-radius: 8; -fx-padding: 8 14; -fx-cursor: hand;"/>
            <Button text="💾 Exportieren (.csv)"
                    style="-fx-background-color: #9C27B0; -fx-text-fill: white; -fx-background-radius: 8; -fx-padding: 8 14; -fx-cursor: hand;"/>
        </HBox>

        <Separator style="-fx-opacity: 0.3;"/>

        <Label text="🚀 System-Aktionen"
               style="-fx-text-fill: #f44336; -fx-font-weight: bold; -fx-font-size: 14;"/>

        <FlowPane hgap="10" vgap="10">
            <Button text="🔄 System neu starten"
                    style="-fx-background-color: #607D8B; -fx-text-fill: white; -fx-background-radius: 8; -fx-padding: 10 18; -fx-cursor: hand;"/>
            <Button text="🔒 Wartungsmodus"
                    style="-fx-background-color: #795548; -fx-text-fill: white; -fx-background-radius: 8; -fx-padding: 10 18; -fx-cursor: hand;"/>
            <Button text="🚪 Logout"
                    style="-fx-background-color: #b71c1c; -fx-text-fill: white; -fx-background-radius: 8; -fx-padding: 10 18; -fx-cursor: hand; -fx-font-weight: bold;"/>
        </FlowPane>

    </VBox>
</ScrollPane>


